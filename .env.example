# MongoDB
MONGODB_URI=mongodb://localhost:27017

# AWS Textract
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Google Document AI
GOOGLE_PROJECT_ID=
GOOGLE_PROCESSOR_ID=
GOOGLE_LOCATION=us
# Service-account credentials: inline JSON or a path to the key file.
# Either var works (a Vertex AI service account is fine as long as it has the
# Document AI API role roles/documentai.apiUser). If both are empty the client
# falls back to Application Default Credentials (GOOGLE_APPLICATION_CREDENTIALS).
GOOGLE_APPLICATION_CREDENTIALS_JSON=
GOOGLE_VERTEX_CREDENTIALS=

# Gemini (all Gemini models)
GEMINI_API_KEY=

# Azure Document Intelligence
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# Mistral (OCR + Pixtral Vision models)
MISTRAL_API_KEY=

# Adobe PDF Extract API
ADOBE_CLIENT_ID=
ADOBE_CLIENT_SECRET=

# ABBYY Cloud OCR
ABBYY_APPLICATION_ID=
ABBYY_PASSWORD=

# Nanonets
NANONETS_API_KEY=
NANONETS_MODEL_ID=OCR

# Klippa OCR
KLIPPA_API_KEY=
