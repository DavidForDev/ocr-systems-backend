# MongoDB
MONGODB_URI=mongodb://localhost:27017

# AWS Textract
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Google Document AI
# Minimum setup: just paste your service-account JSON here (inline or a file
# path). project_id is read from the JSON, location defaults to "us", and an
# OCR processor is auto-discovered — or created if none exists (the account
# then needs roles/documentai.editor, otherwise set GOOGLE_PROCESSOR_ID below).
GOOGLE_VERTEX_CREDENTIALS=
# Optional overrides:
GOOGLE_LOCATION=us
GOOGLE_PROJECT_ID=
GOOGLE_PROCESSOR_ID=
# Alias for the credentials var (same behaviour as GOOGLE_VERTEX_CREDENTIALS):
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# Gemini (all Gemini models)
GEMINI_API_KEY=

# Azure Document Intelligence
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# Mistral (OCR + Pixtral Vision models)
MISTRAL_API_KEY=

# Adobe PDF Extract API
ADOBE_CLIENT_ID=
ADOBE_CLIENT_SECRET=

# ABBYY Cloud OCR
ABBYY_APPLICATION_ID=
ABBYY_PASSWORD=

# Nanonets
NANONETS_API_KEY=
NANONETS_MODEL_ID=OCR

# Klippa OCR
KLIPPA_API_KEY=
