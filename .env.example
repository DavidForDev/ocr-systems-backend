# MongoDB
MONGODB_URI=mongodb://localhost:27017

# Cloudflare R2 (object storage for run + dataset images)
# Leave any of these blank to fall back to local ./uploads (dev only).
R2_ACCOUNT_ID=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Public URL prefix — Cloudflare's r2.dev subdomain (enable Public Access on
# the bucket) or a custom domain. No trailing slash.
# Example: https://pub-1234abcd.r2.dev
R2_PUBLIC_BASE_URL=

# AWS Textract
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Google Document AI
# Auth: point GOOGLE_APPLICATION_CREDENTIALS at a service-account key file
# (standard ADC). The account needs roles/documentai.apiUser (or .editor if you
# want the OCR processor auto-created when GOOGLE_DOCUMENTAI_PROCESSOR_ID is unset).
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GOOGLE_DOCUMENTAI_PROJECT_ID=
GOOGLE_DOCUMENTAI_LOCATION=us
GOOGLE_DOCUMENTAI_PROCESSOR_ID=
# Alternative to a key file (e.g. on Railway): inline JSON or a path.
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# Gemini (all Gemini models)
GEMINI_API_KEY=

# Azure Document Intelligence
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# Mistral (OCR + Pixtral Vision models)
MISTRAL_API_KEY=

# Surya OCR via Datalab hosted API (https://www.datalab.to)
DATALAB_API_KEY=

# Adobe PDF Extract API
ADOBE_CLIENT_ID=
ADOBE_CLIENT_SECRET=

# ABBYY Cloud OCR
ABBYY_APPLICATION_ID=
ABBYY_PASSWORD=

# Nanonets
NANONETS_API_KEY=
NANONETS_MODEL_ID=OCR

# Klippa OCR
KLIPPA_API_KEY=
